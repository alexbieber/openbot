# ─────────────────────────────────────────────────────────────
# OpenBot — Environment Configuration
# Copy this file to .env and fill in the values you need.
# You only need ONE AI provider key to get started.
# ─────────────────────────────────────────────────────────────

# ── AI Provider Keys (choose one or more) ────────────────────

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Groq (ultra-fast inference)
GROQ_API_KEY=gsk_...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Together AI
TOGETHER_API_KEY=...

# Mistral AI
MISTRAL_API_KEY=...

# OpenRouter (routes to many providers)
OPENROUTER_API_KEY=sk-or-...

# Ollama (local models — set URL of your Ollama server)
OLLAMA_URL=http://localhost:11434

# xAI Grok
XAI_API_KEY=xai-...

# Cohere
COHERE_API_KEY=...

# ── Gateway Settings ─────────────────────────────────────────

# Host and port (default: 127.0.0.1:18789)
OPENBOT_HOST=127.0.0.1
OPENBOT_PORT=18789

# Auth token for mobile app / external connections (leave empty for local-only)
OPENBOT_AUTH_TOKEN=

# Default model to use (examples below)
# OPENBOT_MODEL=claude-sonnet-4-6
# OPENBOT_MODEL=gpt-4o
# OPENBOT_MODEL=gemini-2.0-flash
# OPENBOT_MODEL=llama-3.3-70b-versatile

# ── Messaging Channels ───────────────────────────────────────

# Telegram Bot
TELEGRAM_BOT_TOKEN=...

# Discord Bot
DISCORD_BOT_TOKEN=...
DISCORD_GUILD_ID=...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# WhatsApp (via whatsapp-web.js — scans QR at startup)
WHATSAPP_ENABLED=true

# Signal (via signal-cli REST API)
SIGNAL_CLI_URL=http://localhost:8080

# Matrix / Element
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_USER_ID=@yourbot:matrix.org
MATRIX_ACCESS_TOKEN=...

# Microsoft Teams
TEAMS_APP_ID=...
TEAMS_APP_PASSWORD=...

# Twitch
TWITCH_BOT_USERNAME=...
TWITCH_BOT_TOKEN=oauth:...
TWITCH_CHANNEL=...

# Gmail (OAuth)
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...

# Outlook / Microsoft 365
OUTLOOK_CLIENT_ID=...
OUTLOOK_CLIENT_SECRET=...
OUTLOOK_TENANT_ID=...

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_CHANNEL_SECRET=...

# WeChat Official Account
WECHAT_APP_ID=...
WECHAT_APP_SECRET=...
WECHAT_TOKEN=...

# Slack Channel ID for broadcasting
SLACK_CHANNEL_ID=...

# ── Skills & Integrations ────────────────────────────────────

# Web search (Brave Search API — free tier available)
BRAVE_API_KEY=BSA...

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=fc-...

# OpenWeather API
OPENWEATHER_API_KEY=...

# News API
NEWS_API_KEY=...

# GitHub (for github skill)
GITHUB_TOKEN=ghp_...

# Home Assistant
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=...

# ── Advanced ─────────────────────────────────────────────────

# Enable Tailscale tunneling (expose gateway via Tailscale network)
# TAILSCALE_ENABLED=true

# Wake word engine (porcupine)
# PORCUPINE_API_KEY=...

# Docker sandbox for code execution
# DOCKER_SANDBOX_IMAGE=python:3.12-slim

# Obsidian vault path for memory sync
# OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Node ACP bus port (multi-agent coordination)
# ACP_PORT=18790
